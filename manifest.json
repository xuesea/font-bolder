{
  "name": "Page Font Bolder",
  "version": "2.2.0",
  "description": "Make page fonts bolder and darker for better readability.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Adjust page font boldness.",
    "default_popup": "src/popup/popup.html"
  },
  "manifest_version": 3,
  "background": {
    "service_worker": "src/background/background.js"
  },
  "commands": {
    "toggle-extension": {
      "suggested_key": {
        "default": "Alt+B"
      },
      "description": "Toggle Font Bolder"
    },
    "cycle-preset": {
      "suggested_key": {
        "default": "Alt+Shift+B"
      },
      "description": "Cycle Font Bolder preset"
    }
  }
}
